model {
  // Actors
  architect = person "Architect" {
    description "Uses DSS for architecture decisions"
  }

  developer = person "Developer" {
    description "Queries knowledge base"
  }

  ba = person "Business Analyst" {
    description "Uses DSS for requirements support"
  }

  pm = person "Project Manager" {
    description "Uses DSS for project management"
  }

  // DSS
  dss = softwareSystem "DSS" {
    description "Decision Support System — RAG-powered architecture knowledge API"

    apiGateway = container "API Gateway" {
      description "NestJS HTTP server — auth, routing, request orchestration"
      technology "NestJS, TypeScript"
    }

    agentOrchestrator = container "Agent Orchestrator" {
      description "Mastra runtime — agent registry, intent routing, tool management"
      technology "Mastra, TypeScript"

      routingAgent = component "Routing Agent" {
        description "Top-level Mastra Agent — intent classification, delegation to sub-agents"
        technology "Mastra Agent"
      }

      agentRegistry = component "Agent Registry" {
        description "Registration and discovery of specialized agents"
        technology "Mastra Agent Network"
      }

      toolRegistry = component "Tool Registry" {
        description "Shared and per-agent tools (Jira, Confluence, Bitbucket, K8s)"
        technology "Mastra Tools, Zod"
      }

      memoryManager = component "Memory Manager" {
        description "Session state, working memory, semantic recall across conversations"
        technology "Mastra Memory, LibSQL/PostgreSQL"
      }

      specializedAgents = component "Specialized Agents" {
        description "SA, BA, PM, Dev, Tester, Reviewer, Frontend, DevOps agents"
        technology "Mastra Agent"
      }
    }

    ragEngine = container "RAG Engine" {
      description "Embedding generation, vector search, context assembly"
      technology "Mastra RAG, pgvector"

      documentProcessor = component "Document Processor" {
        description "Document initialization and chunking (recursive, 512 tokens, overlap 50)"
        technology "Mastra MDocument"
      }

      embeddingService = component "Embedding Service" {
        description "Generates embeddings for documents and queries"
        technology "Mastra ModelRouterEmbeddingModel"
      }

      vectorStoreClient = component "Vector Store Client" {
        description "PgVector wrapper — upsert, query, delete operations"
        technology "Mastra PgVector"
      }

      retrievalService = component "Retrieval Service" {
        description "Query embedding → vector search (topK) → ranked results"
        technology "Mastra RAG"
      }

      contextAssembler = component "Context Assembler" {
        description "Formats retrieved chunks into LLM-ready context with source references"
        technology "TypeScript"
      }
    }

    ingestionPipeline = container "Ingestion Pipeline" {
      description "Scheduled crawling & indexing from knowledge sources"
      technology "NestJS, Mastra Syncs"
    }

    discordBot = container "Discord Bot" {
      description "Channel adapter — Discord interaction"
      technology "Discord.js"
    }

    mcpServer = container "MCP Server" {
      description "Channel adapter — MCP protocol for Claude Code and other MCP clients"
      technology "MCP SDK, SSE/stdio"
    }
  }

  // External Systems
  discord = externalSystem "Discord" {
    description "Source of team discussions"
  }

  confluence = externalSystem "Confluence" {
    description "Documentation source"
  }

  jira = externalSystem "Jira" {
    description "Project management source"
  }

  bitbucket = externalSystem "Bitbucket" {
    description "Source code repository"
  }

  llmProvider = externalSystem "LLM Provider" {
    description "Claude API (Anthropic)"
  }

  vectorDb = database "PostgreSQL + pgvector" {
    description "Vector storage for embeddings, agent state, metadata"
  }

  // ── System Context Relationships ──

  architect .sync dss "Queries architecture knowledge"
  developer .sync dss "Searches decisions & patterns"
  ba .sync dss "Requirements elicitation"
  pm .sync dss "Project management support"

  dss .async discord "Ingests discussions"
  dss .async confluence "Ingests documentation"
  dss .async jira "Ingests issues & tasks"
  dss .async bitbucket "Ingests source code"
  dss .sync llmProvider "Generates embeddings & responses"
  dss .sync vectorDb "Stores/retrieves vectors"

  // ── Container Relationships ──

  // Inbound: Channels → API Gateway
  discordBot .sync apiGateway "Forwards user messages"
  mcpServer .sync apiGateway "Forwards MCP requests"

  // Core: API Gateway → Agent Orchestrator → RAG Engine
  apiGateway .sync agentOrchestrator "Routes to agents"
  agentOrchestrator .sync ragEngine "Retrieves context"
  agentOrchestrator .sync llmProvider "Agent LLM calls"

  // RAG Engine → Storage
  ragEngine .reads vectorDb "Vector search & retrieval"
  ragEngine .sync llmProvider "Embedding generation"

  // Ingestion: Pipeline → Sources & Storage
  ingestionPipeline .async discord "Crawls messages"
  ingestionPipeline .async confluence "Crawls pages"
  ingestionPipeline .async jira "Crawls issues"
  ingestionPipeline .async bitbucket "Crawls repositories"
  ingestionPipeline .sync ragEngine "Sends documents for embedding"
  ingestionPipeline .writes vectorDb "Stores metadata & vectors"

  // Channel adapters → External
  discordBot .sync discord "Listens & sends messages"

  // ── Agent Orchestrator Component Relationships ──

  routingAgent .sync agentRegistry "Discovers available agents"
  routingAgent .sync specializedAgents "Delegates tasks"
  specializedAgents .sync toolRegistry "Uses tools"
  specializedAgents .sync ragEngine "Retrieves RAG context"
  routingAgent .sync memoryManager "Reads/writes session state"
  specializedAgents .sync memoryManager "Reads/writes working memory"
  agentRegistry .sync specializedAgents "Registers agents"

  // ── RAG Engine Component Relationships ──

  retrievalService .sync embeddingService "Embeds query"
  retrievalService .sync vectorStoreClient "Vector search"
  retrievalService .sync contextAssembler "Assembles context"
  documentProcessor .sync embeddingService "Embeds chunks"
  embeddingService .sync llmProvider "Embedding API calls"
  vectorStoreClient .sync vectorDb "pgvector operations"
}
