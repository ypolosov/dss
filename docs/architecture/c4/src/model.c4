model {
  // Actors
  architect = person "Architect" {
    description "Uses DSS for architecture decisions"
  }

  developer = person "Developer" {
    description "Queries knowledge base"
  }

  // DSS
  dss = softwareSystem "DSS" {
    description "Decision Support System — RAG-powered architecture knowledge API"

    // Containers (to be detailed in iterations)
    // api = container "DSS API" - NestJS + Mastra
    // ragPipeline = container "RAG Pipeline" - embedding & retrieval
    // discordBot = container "Discord Bot" - team interaction
  }

  // External Systems
  discord = externalSystem "Discord" {
    description "Source of team discussions"
  }

  confluence = externalSystem "Confluence" {
    description "Documentation source"
  }

  jira = externalSystem "Jira" {
    description "Project management source"
  }

  llmProvider = externalSystem "LLM Provider" {
    description "Claude API (Anthropic)"
  }

  vectorDb = database "PostgreSQL + pgvector" {
    description "Vector storage for embeddings"
  }

  // System Context Relationships
  architect -> dss "Queries architecture knowledge" { style sync }
  developer -> dss "Searches decisions & patterns" { style sync }
  dss -> discord "Ingests discussions" { style async }
  dss -> confluence "Ingests documentation" { style async }
  dss -> jira "Ingests issues & tasks" { style async }
  dss -> llmProvider "Generates embeddings & responses" { style sync }
  dss -> vectorDb "Stores/retrieves vectors" { style sync }
}
