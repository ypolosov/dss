{
  "name": "dss-architecture-c4",
  "version": "0.1.0",
  "private": true,
  "description": "DSS API C4 architecture diagrams using LikeC4",
  "scripts": {
    "install-deps": "npx playwright install --with-deps chromium",
    "likec4": "likec4",
    "preview": "likec4 preview",
    "build": "likec4 build --no-use-dot",
    "gen": "likec4 gen",
    "start": "likec4 start --no-use-dot",
    "export": "likec4 export png -o ./out --sequence",
    "validate": "likec4 validate",
    "check-update": "likec4 check-update"
  },
  "devDependencies": {
    "likec4": "^1.50.0"
  }
}